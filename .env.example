# Supabase Auth & API (frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Invite email delivery (Resend)
RESEND_API_KEY=re_xxxxxxxxx
INVITE_FROM_EMAIL=My Finances <invite@yourdomain.com>
INVITE_REPLY_TO=support@yourdomain.com

# PostgreSQL Database (Prisma)
# Use Transaction pooler for DATABASE_URL
# Use Direct connection for DIRECT_URL (migrations only)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:[6543]/postgres?pgbouncer=true&schema=public
DIRECT_URL=postgresql://postgres:[PASSWORD]@[HOST]:[5432]/postgres?schema=public
