# Supabase public keys (frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional invite email delivery via Resend
RESEND_API_KEY=re_xxxxxxxxx
INVITE_FROM_EMAIL=My Finances <invite@yourdomain.com>

# PostgreSQL connection used by Prisma
DATABASE_URL=postgresql://user:password@localhost:5432/my_finances?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/my_finances?schema=public
